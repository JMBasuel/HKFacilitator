    </style>

    <style name="TextInputStyle" parent="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">
        <item name="counterTextColor">@color/black</item>
        <item name="hintTextColor">@color/gray_dark</item>
        <item name="backgroundTint">@color/gray_dark</item>
        <item name="android:textColorHint">@color/gray_dark</item>
        <item name="endIconTint">@color/gray_dark</item>
        <item name="errorTextColor">@color/red</item>
        <item name="boxStrokeColor">@color/gray_dark</item>
        <item name="boxStrokeErrorColor">@color/red</item>
        <item name="cursorColor">@color/gray_dark</item>
        <item name="errorIconTint">@color/red</item>
        <item name="passwordToggleTint">@color/gray_dark</item>
        <item name="startIconTint">@color/gray_dark</item>
        <item name="helperTextTextColor">@color/red</item>
